// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- User and Auth Models ---

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  passwordResetTokens   PasswordResetToken[]
  refreshTokens         RefreshToken[] // Add this relation
  notifications         Notification[]
  createdTransactions   Transaction[]        @relation("CreatedByUser")
  createdPurchaseOrders PurchaseOrder[]      @relation("CreatedByUser")
  createdSalesOrders    SalesOrder[]         @relation("CreatedByUser")
  auditLogs             AuditLog[]           @relation("PerformedByUser")

  @@index([email])
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique // Store a hash of the token
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique // Store a hash of the actual token (e.g., SHA256)
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false) // Flag to indicate if token was manually revoked (logout, etc.)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade) // Cascade delete ensures tokens are removed if user is deleted

  @@index([userId])
  @@index([expiresAt]) // Useful for cleanup jobs
}

// --- Core Inventory Models ---

model Product {
  id           String   @id @default(uuid())
  sku          String   @unique // Stock Keeping Unit - Essential!
  name         String
  description  String?  @db.Text
  categoryId   String?
  unit         String   @default("pcs") // e.g., pcs, kg, ltr, box
  reorderLevel Int      @default(0) // Threshold for low stock notification
  costPrice    Float?   @default(0.0)
  sellingPrice Float?   @default(0.0)
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stockLevels        StockLevel[] // Where this product is stored
  transactions       Transaction[] // History of movements for this product
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]

  @@index([name])
  @@index([categoryId])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  products Product[] // Products in this category
}

model Location {
  id          String   @id @default(uuid())
  name        String   @unique
  address     String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  stockLevels StockLevel[] // Stock present at this location

  // Corresponding relations for transactions using the defined names
  transactionsFrom Transaction[] @relation("TransactionsFrom") // Transactions originating FROM this location
  transactionsTo   Transaction[] @relation("TransactionsTo") // Transactions arriving TO this location
  Transaction      Transaction[]
}

// Represents the actual quantity of a specific product at a specific location
model StockLevel {
  id          String   @id @default(uuid())
  productId   String
  locationId  String
  quantity    Int      @default(0) // Current quantity on hand
  lastUpdated DateTime @updatedAt // Automatically updated when quantity changes

  // Relations
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId]) // A product can only have one stock level entry per location
  @@index([productId])
  @@index([locationId])
}

// --- Transaction and Movement Models ---

model Transaction {
  id             String          @id @default(uuid())
  type           TransactionType
  productId      String
  quantityChange Int // Positive for IN, Negative for OUT
  notes          String?         @db.Text
  timestamp      DateTime        @default(now())
  userId         String // User who recorded the transaction
  relatedPoId    String? // Link to Purchase Order if applicable
  relatedSoId    String? // Link to Sales Order if applicable

  // Explicit Location Tracking
  sourceLocationId      String? // Where stock came FROM (required for SALE, ADJ_OUT, TRANSFER_OUT)
  destinationLocationId String? // Where stock went TO (required for PURCHASE, ADJ_IN, TRANSFER_IN)

  // Relations
  product       Product        @relation(fields: [productId], references: [id])
  user          User           @relation("CreatedByUser", fields: [userId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [relatedPoId], references: [id], onDelete: SetNull)
  salesOrder    SalesOrder?    @relation(fields: [relatedSoId], references: [id], onDelete: SetNull)

  // Explicit named relations for locations
  sourceLocation      Location? @relation("TransactionsFrom", fields: [sourceLocationId], references: [id], onDelete: SetNull)
  destinationLocation Location? @relation("TransactionsTo", fields: [destinationLocationId], references: [id], onDelete: SetNull)
  Location            Location? @relation(fields: [locationId], references: [id])
  locationId          String?

  @@index([productId])
  @@index([userId])
  @@index([type])
  @@index([timestamp])
  @@index([sourceLocationId])
  @@index([destinationLocationId])
  @@index([relatedPoId])
  @@index([relatedSoId])
}

enum TransactionType {
  PURCHASE // Stock In from Supplier
  SALE // Stock Out to Customer
  ADJUSTMENT_IN // Manual Increase
  ADJUSTMENT_OUT // Manual Decrease
  TRANSFER_OUT // Stock sent TO another internal location (decreases source)
  TRANSFER_IN // Stock received FROM another internal location (increases destination)
  // You might handle transfers as a linked pair: one TRANSFER_OUT and one TRANSFER_IN
}

// --- Supplier and Order Models ---

model Supplier {
  id            String   @id @default(uuid())
  name          String   @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  purchaseOrders PurchaseOrder[] // POs placed with this supplier
}

model PurchaseOrder {
  id                   String      @id @default(uuid())
  orderNumber          String      @unique // Auto-generate or manual
  supplierId           String
  userId               String // User who created the PO
  status               OrderStatus @default(PENDING)
  orderDate            DateTime    @default(now())
  expectedDeliveryDate DateTime?
  notes                String?     @db.Text
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Relations
  supplier            Supplier            @relation(fields: [supplierId], references: [id])
  user                User                @relation("CreatedByUser", fields: [userId], references: [id])
  items               PurchaseOrderItem[]
  relatedTransactions Transaction[] // Transactions created when stock is received
}

model PurchaseOrderItem {
  id               String @id @default(uuid())
  purchaseOrderId  String
  productId        String
  quantityOrdered  Int
  quantityReceived Int    @default(0)
  unitCost         Float // Cost at the time of order

  // Relations
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

// Optional: Sales Orders (if tracking customer orders)
model SalesOrder {
  id           String      @id @default(uuid())
  orderNumber  String      @unique // Auto-generate or manual
  customerRef  String? // Simple customer reference (name, ID, etc.)
  userId       String // User who created the SO
  status       OrderStatus @default(PENDING)
  orderDate    DateTime    @default(now())
  shippingDate DateTime?
  notes        String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  user                User             @relation("CreatedByUser", fields: [userId], references: [id])
  items               SalesOrderItem[]
  relatedTransactions Transaction[] // Transactions created when stock is shipped
}

model SalesOrderItem {
  id              String @id @default(uuid())
  salesOrderId    String
  productId       String
  quantityOrdered Int
  quantityShipped Int    @default(0)
  unitPrice       Float // Price at the time of order

  // Relations
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING // Order created, awaiting action
  APPROVED // PO Approved for purchase / SO Confirmed by customer
  PROCESSING // Being fulfilled (Optional intermediate step)
  RECEIVED // PO items received / SO items ready (if applicable)
  SHIPPED // SO items shipped
  PARTIAL // Partially received/shipped
  COMPLETED // Fully received/shipped and finalized
  CANCELLED // Order cancelled
}

// --- System & Utility Models ---

model Notification {
  id                String            @id @default(uuid())
  userId            String // User who should receive this notification
  message           String
  isRead            Boolean           @default(false)
  type              NotificationType? // Optional: Categorize notifications
  relatedEntityId   String? // Optional: Link to Product, Order, etc.
  relatedEntityType String? // Optional: Type of related entity ("Product", "PurchaseOrder")
  createdAt         DateTime          @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  LOW_STOCK
  ORDER_STATUS_UPDATE
  STOCK_ADJUSTMENT
  USER_MENTION // Example if you add commenting features
  SYSTEM_ALERT
}

model AuditLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  userId    String? // User performing the action (null for system actions)
  action    String // e.g., "CREATE_PRODUCT", "UPDATE_STOCK", "LOGIN_SUCCESS", "DELETE_USER"
  entity    String? // e.g., "Product", "User", "StockLevel"
  entityId  String? // ID of the affected entity
  details   Json? // Store before/after state or additional context (be mindful of size/PII)

  // Relations
  user User? @relation("PerformedByUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
}
