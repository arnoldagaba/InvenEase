# Server port
PORT=port_number

# Database
DATABASE_URL="mysql://johndoe:randompassword@localhost:3306/mydb"

# Node environment
NODE_ENV=development # or production

# Optional: Winston log level override (defaults based on NODE_ENV)
LOG_LEVEL=debug

# Optional: Directory for log files (defaults to project_root/logs)
LOG_DIR=/var/log/my-app

# Optional: Force file logging even in development
LOG_TO_FILES=true

# JWT Secrets
JWT_ACCESS_SECRET=your_secret
JWT_ACCESS_EXPIRATION=1d
JWT_REFRESH_SECRET=your_secret
JWT_REFRESH_EXPIRATION=7d
REFRESH_TOKEN_EXPIRATION_MINUTES=60

# Mail options
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="5fGtL@example.com"
EMAIL_PASS="password"
EMAIL_FROM="5fGtL@example.com"
CLIENT_URL="http://localhost:5173"